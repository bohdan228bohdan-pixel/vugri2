# Copy this file to .env and fill values (DO NOT commit your .env)
# Example .env for local development

# Django Secret Key
DJANGO_SECRET_KEY=your-secret-key

# Email Backend Configuration
# Option 1: Gmail SMTP (legacy, not recommended)
# DJANGO_EMAIL_USER=dieller7073@gmail.com
# DJANGO_EMAIL_PASSWORD=YOUR_16_CHAR_APP_PASSWORD_WITHOUT_SPACES
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DJANGO_EMAIL_HOST=smtp.gmail.com
# DJANGO_EMAIL_PORT=587
# DJANGO_EMAIL_USE_TLS=True
# DJANGO_EMAIL_USE_SSL=False

# Default From Email
DJANGO_DEFAULT_FROM_EMAIL=noreply@vugriukraine.com

# Option 2: Brevo (SendinBlue) - Recommended
BREVO_API_KEY=your_v3_api_key_from_brevo
BREVO_SENDER_EMAIL=noreply@vugriukraine.com
BREVO_SENDER_NAME=VugriUkraine

# Order Notifications
ORDER_NOTIFICATION_EMAIL=admin@vugriukraine.com
ADMIN_EMAIL=admin@vugriukraine.com

# Optional: Database (defaults to SQLite)
# DJANGO_DB_ENGINE=django.db.backends.postgresql
# DJANGO_DB_NAME=vugri_db
# DJANGO_DB_USER=postgres
# DJANGO_DB_PASSWORD=your_password

# Optional: Security
DJANGO_DEBUG=False
DJANGO_SECURE_SSL_REDIRECT=True

# Optional: Time Zone
DJANGO_TIME_ZONE=Europe/Kyiv
