# Copy this file to .env and fill values (DO NOT commit your .env)
# Example .env for local development

# Django Settings
DJANGO_SECRET_KEY=your-secret-key
DJANGO_DEBUG=False
DJANGO_TIME_ZONE=Europe/Kyiv

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# Default From Email
DEFAULT_FROM_EMAIL=noreply@vugriukraine.com

# Brevo (SendinBlue) Configuration
BREVO_API_KEY=your_v3_api_key_from_brevo
BREVO_SENDER_EMAIL=noreply@vugriukraine.com
BREVO_SENDER_NAME=VugriUkraine

# Order & Admin Notifications
ORDER_NOTIFICATION_EMAIL=admin@vugriukraine.com
ADMIN_EMAIL=admin@vugriukraine.com

# Database Configuration (optional - defaults to SQLite)
# DATABASE_URL=postgresql://user:password@localhost/vugri_db

# Security (for production)
DJANGO_SECURE_SSL_REDIRECT=True
ALLOWED_HOSTS=vugri2.onrender.com,localhost,127.0.0.1
